{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "Run Tests Script Settings",
  "description": "maksit-webui: Jest tests and shields.io coverage badges in README.md.",
  "paths": {
    "readmePath": "..\\..\\..\\README.md"
  },
  "plugins": [
    {
      "name": "NpmJestTest",
      "stageLabel": "test",
      "enabled": true,
      "workspaceRoot": "..\\..\\..\\src",
      "testScript": "test:coverage",
      "coverageDirectory": "coverage"
    },
    {
      "name": "QualityGate",
      "stageLabel": "qualityGate",
      "enabled": true,
      "coverageThreshold": 0,
      "scanVulnerabilities": false
    },
    {
      "name": "CoverageBadges",
      "stageLabel": "report",
      "enabled": true,
      "badgeFormat": "shields",
      "readmePath": "..\\..\\..\\README.md",
      "badges": [
        {
          "label": "Line Coverage",
          "metric": "line"
        },
        {
          "label": "Branch Coverage",
          "metric": "branch"
        },
        {
          "label": "Method Coverage",
          "metric": "method"
        }
      ],
      "colorThresholds": {
        "brightgreen": 80,
        "green": 60,
        "yellowgreen": 40,
        "yellow": 20,
        "orange": 10,
        "red": 0
      }
    }
  ]
}
